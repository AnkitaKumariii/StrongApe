# App Configuration
APP_NAME="StrongApe API"
DEBUG=True

# Security Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY="replace_me_with_a_secure_random_hex_string"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# SQLite works out of the box for local development (no Docker required)
DATABASE_URL="sqlite+aiosqlite:///./strongape.db"

# PostgreSQL (production / Docker): run `docker-compose up -d` first, then use:
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/strongape"

# Google Gemini (Food Scanner & Workout Routines)
# Get an API key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"
# Comma-separated fallbacks if the primary model hits quota limits
GEMINI_FALLBACK_MODELS="gemini-2.5-flash-lite,gemini-1.5-flash"
