# App Configuration
APP_NAME="StrongApe API"
DEBUG=True

# Security Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY="replace_me_with_a_secure_random_hex_string"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# Local Docker DB URL
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/strongape"

# For tests, SQLite async in-memory or aiosqlite file is used automatically.
